<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="<%= url %>/styles/main.css" rel="stylesheet" />
  </head>

  <body>
    <div
      class="min-h-screen flex items-center justify-center gradient-background relative overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-20"
        style="background-image: url(<%= url %>/images/background.jpg)"
      ></div>
      <div
        class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/10"
      ></div>
      <div class="relative z-10 w-full max-w-lg px-6">
        <div class="text-center space-y-4 mb-8">
          <div class="flex justify-center items-center space-x-2">
            <span
              class="badge bg-primary/10 text-primary border-primary/20 px-3 py-1"
            >
              ALIKA
            </span>
          </div>

          <div class="space-y-2">
            <h2
              class="text-sm font-medium text-base-content uppercase tracking-wider"
            >
              Sekretariat Direktorat Jenderal Kekayaan Negara
            </h2>
            <h1
              class="text-4xl font-bold bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-base-content"
            ></h1>
          </div>

          <div class="w-24 h-1 bg-gradient-primary mx-auto rounded-full"></div>
        </div>
        <div
          class="rounded-lg bg-base-100 text-base-content shadow-sm w-full max-w-md shadow-base-content/20 border-0"
        >
          <div class="flex flex-col p-6 text-center space-y-6 pb-8">
            <div class="flex justify-center">
              <div
                class="w-20 h-20 bg-primary rounded-full flex items-center justify-center shadow-base-content/20"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-10 h-10 text-primary-content"
                >
                  <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"></path>
                  <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"></path>
                  <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"></path>
                  <path d="M10 6h4"></path>
                  <path d="M10 10h4"></path>
                  <path d="M10 14h4"></path>
                  <path d="M10 18h4"></path>
                </svg>
              </div>
            </div>
            <div class="space-y-2">
              <h1 class="text-2xl font-bold text-base-content">ALIKA DJKN</h1>
            </div>
          </div>
          <div class="p-6 pt-0 space-y-6">
            <div class="my-4 font-bold text-center w-full">
              <span class="loading loading-spinner text-primary"></span>
            </div>
          </div>
        </div>
        <div class="mt-8 text-center">
          <p class="text-xs text-base-content">
            © 2025 Sekretariat Direktorat Jenderal Kekayaan Negara
          </p>
        </div>
      </div>
      <div
        class="absolute top-10 left-10 w-32 h-32 bg-primary/5 rounded-full blur-3xl"
      ></div>
      <div
        class="absolute bottom-10 right-10 w-40 h-40 bg-primary/3 rounded-full blur-3xl"
      ></div>
    </div>
  </body>
  <script>
    const theme = localStorage.getItem("theme");
    document.documentElement.setAttribute("data-theme", theme ? theme : "blue");
  </script>
  <script>
    setTimeout(function () {
      window.location.href = "/";
    }, 500);
  </script>
</html>
