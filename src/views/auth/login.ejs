<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="<%= url %>/styles/main.css" rel="stylesheet" />
  </head>

  <body>
    <div
      class="min-h-screen flex items-center justify-center gradient-background relative overflow-hidden py-5"
    >
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-20"
        style="background-image: url(<%= url %>/images/background.jpg)"
      ></div>
      <div
        class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/10"
      ></div>
      <div class="relative z-10 w-full max-w-lg px-6">
        <div class="text-center space-y-4 mb-8">
          <div class="flex justify-center items-center space-x-2">
            <span
              class="badge bg-primary/10 text-primary border-primary/20 px-3 py-1"
            >
              ALIKA
            </span>
          </div>

          <div class="space-y-2">
            <h2
              class="text-sm font-medium text-base-content uppercase tracking-wider"
            >
              Direktorat Jenderal Kekayaan Negara
            </h2>
            <h1
              class="text-4xl font-bold bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-base-content"
            >Kementerian Keuangan</h1>
          </div>

          <div class="w-24 h-1 bg-gradient-primary mx-auto rounded-full"></div>
        </div>
        <div
          class="rounded-lg bg-base-100 text-base-content shadow-sm w-full max-w-md shadow-base-content/20 border-0"
        >
          <div class="flex flex-col p-6 text-center space-y-6 pb-8">
            <div class="flex justify-center">
              <div
                class="w-20 h-20 bg-primary rounded-full flex items-center justify-center shadow-base-content/20"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-10 h-10 text-primary-content"
                >
                  <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"></path>
                  <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"></path>
                  <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"></path>
                  <path d="M10 6h4"></path>
                  <path d="M10 10h4"></path>
                  <path d="M10 14h4"></path>
                  <path d="M10 18h4"></path>
                </svg>
              </div>
            </div>
            <div class="space-y-2">
              <h1 class="text-2xl font-bold text-base-content">ALIKA DJKN</h1>
              <p class="text-neutral">
                Masuk dengan akun SSO Kementerian Keuangan
              </p>
            </div>
          </div>
          <div class="p-6 pt-0 space-y-6">
            <div class="space-y-4">
              <form action="<%= url %>/login/KemenkeuID" method="post">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button
                  class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-primary-300 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0 bg-primary text-primary-content hover:bg-primary/90 h-11 rounded-md px-8 w-full gov-button text-base font-semibold cursor-pointer"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path
                      d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
                    ></path>
                  </svg>
                  Login With Kemenkeu ID
                </button>
              </form>
            </div>
          </div>
        </div>
        <div class="mt-8 text-center">
          <p class="text-xs text-base-content">
            © 2025 Sekretariat Direktorat Jenderal Kekayaan Negara
          </p>
        </div>
      </div>
      <div
        class="absolute top-10 left-10 w-32 h-32 bg-primary/5 rounded-full blur-3xl"
      ></div>
      <div
        class="absolute bottom-10 right-10 w-40 h-40 bg-primary/3 rounded-full blur-3xl"
      ></div>
    </div>
  </body>
  <script>
    const theme = localStorage.getItem("theme");

    document.documentElement.setAttribute("data-theme", theme ? theme : "blue");
  </script>
</html>
